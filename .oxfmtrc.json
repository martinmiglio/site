{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "useTabs": false,
  "tabWidth": 2,
  "printWidth": 100,
  "singleQuote": true,
  "jsxSingleQuote": false,
  "quoteProps": "as-needed",
  "trailingComma": "none",
  "semi": false,
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "ignorePatterns": [
    "**/dist",
    "**/node_modules",
    "**/src/routeTree.gen.ts",
    "**/src/assets/index.css",
    "**/.output",
    "**/.tanstack",
    "**/.nitro",
    "**/.sst",
    "**/bun.lockb"
  ]
}
