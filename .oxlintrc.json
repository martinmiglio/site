{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc", "react", "jsx-a11y"],
  "categories": {
    "correctness": "error"
  },
  "rules": {},
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "**/dist",
    "**/node_modules",
    "**/src/routeTree.gen.ts",
    "**/src/lib/pdf/fonts/*.ts",
    "**/.output",
    "**/.tanstack",
    "**/.nitro",
    "**/.sst"
  ],
  "overrides": [
    {
      "files": ["sst.config.ts", "infra/**/*.ts"],
      "rules": {
        "triple-slash-reference": "off"
      }
    }
  ]
}
